// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  position     String?
  role         String   @default("MANAGER")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  counterparties         Counterparty[] @relation("CounterpartyCreatedBy")
  counterpartiesUpdated  Counterparty[] @relation("CounterpartyUpdatedBy")
  counterpartiesManaged  Counterparty[] @relation("CounterpartyManager")
  projects               Project[]      @relation("ProjectManager")
  projectsUpdated        Project[]      @relation("ProjectUpdatedBy")
  dealsAsManager         Deal[]         @relation("DealManager")
  dealsAsAuthor          Deal[]         @relation("DealCreatedBy")
  dealsUpdated           Deal[]         @relation("DealUpdatedBy")
  invites                Invite[]       @relation("InviteCreatedBy")
  tasksAsAssignee        Task[]         @relation("TaskAssignee")
  tasksAsAuthor          Task[]         @relation("TaskCreatedBy")
  shipmentsCreated       Shipment[]     @relation("ShipmentCreatedBy")
  shipmentsUpdated       Shipment[]     @relation("ShipmentUpdatedBy")
  notes                  Note[]         @relation("NoteAuthor")
  attachments            Attachment[]   @relation("AttachmentUploadedBy")
  changeLogs             ChangeLog[]    @relation("ChangeLogAuthor")
  auctionsAsManager      Auction[]      @relation("AuctionManager")
  auctionsAsAuthor       Auction[]      @relation("AuctionCreatedBy")
  auctionsUpdated        Auction[]      @relation("AuctionUpdatedBy")

  @@map("users")
}

model ChangeLog {
  id               String   @id @default(cuid())
  entityType       String
  entityId         String
  parentEntityType String?
  parentEntityId   String?
  action           String
  changes          String?
  authorId         String?
  author           User?    @relation("ChangeLogAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([entityType, entityId])
  @@index([parentEntityType, parentEntityId])
  @@index([createdAt])
  @@map("change_logs")
}

model Invite {
  id          String   @id @default(cuid())
  token       String   @unique
  email       String?
  role        String   @default("MANAGER")
  expiresAt   DateTime
  usedAt      DateTime?
  usedByEmail String?
  createdById String
  createdBy   User     @relation("InviteCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([token])
  @@map("invites")
}

model Counterparty {
  id              String   @id @default(cuid())
  type            String
  name            String
  region          String
  inn             String?
  kpp             String?
  ogrn            String?
  okpo            String?
  okved           String?
  bankName        String?
  bankAccount     String?
  bankCorrAccount String?
  bik             String?
  totalRevenue    Decimal  @default(0)
  discount        Decimal?
  phone           String?
  email           String?
  address         String?
  source          String?
  companyKind     String?
  activityArea    String?
  note            String?
  contacts        Contact[]
  managerId       String?
  manager         User?    @relation("CounterpartyManager", fields: [managerId], references: [id], onDelete: SetNull)
  createdById     String?
  createdBy       User?    @relation("CounterpartyCreatedBy", fields: [createdById], references: [id])
  updatedById     String?
  updatedBy       User?    @relation("CounterpartyUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectsAsDistributor Project[] @relation("ProjectDistributor")
  projectsAsEndCustomer Project[] @relation("ProjectEndCustomer")
  deals                 Deal[]    @relation("DealCounterparty")
  tasksAsDistributor    Task[]    @relation("TaskDistributor")
  tasksAsEndCustomer    Task[]    @relation("TaskEndCustomer")
  auctionsAsCustomer    Auction[] @relation("AuctionCustomer")
  auctionsAsSupplier    Auction[] @relation("AuctionSupplier")

  @@unique([inn, kpp])
  @@index([type])
  @@index([region])
  @@map("counterparties")
}

model Project {
  id                String        @id @default(cuid())
  externalAuctionId String?
  internalName      String
  status            String        @default("IN_PROGRESS")
  totalAmount       Decimal       @default(0)
  auctionDate       DateTime?
  duplicateComment  String?
  lossReason        String?
  lossComment       String?

  distributorId     String
  distributor       Counterparty  @relation("ProjectDistributor", fields: [distributorId], references: [id])
  endCustomerId     String
  endCustomer       Counterparty  @relation("ProjectEndCustomer", fields: [endCustomerId], references: [id])
  managerId         String
  manager           User          @relation("ProjectManager", fields: [managerId], references: [id])
  updatedById       String?
  updatedBy         User?         @relation("ProjectUpdatedBy", fields: [updatedById], references: [id])

  items             ProjectItem[]
  contacts          Contact[]
  tasks             Task[]
  deals             Deal[]        @relation("ProjectDeals")
  auctions          Auction[]     @relation("ProjectAuctions")

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([externalAuctionId, endCustomerId])
  @@index([distributorId])
  @@index([endCustomerId])
  @@index([managerId])
  @@map("projects")
}

model ProjectItem {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku       String?
  name      String
  quantity  Decimal  @default(1)
  amount    Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([productId])
  @@map("project_items")
}

model Product {
  id                  String        @id @default(cuid())
  sku                 String        @unique
  name                String
  category            String
  basePrice           Decimal       @default(0)
  packagePrice        Decimal       @default(0)
  recommendedLpuPrice Decimal?
  transportPackQty    Int           @default(0)
  unitWeightKg        Decimal?
  unitVolumeM3        Decimal?
  contents            String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  projectItems        ProjectItem[]
  dealItems           DealItem[]    @relation("DealItemProduct")
  auctionItems        AuctionItem[] @relation("AuctionItemProduct")
  stocks              Stock[]

  @@index([category])
  @@map("products")
}

model Stock {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse  String
  quantity   Int      @default(0)
  syncedAt   DateTime @default(now())

  @@unique([productId, warehouse])
  @@index([productId])
  @@map("stocks")
}

model Contact {
  id             String        @id @default(cuid())
  counterpartyId String?
  counterparty   Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  firstName      String?
  lastName       String?
  phone          String?
  email          String?
  birthDate      DateTime?
  position       String?
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  projects       Project[]
  deals          Deal[]    @relation("DealContact")
  shipments      Shipment[] @relation("ShipmentRecipient")
  auctions       Auction[] @relation("AuctionSupplierContact")

  @@index([counterpartyId])
  @@map("contacts")
}

model Deal {
  id              String   @id @default(cuid())
  title           String?
  status          String   @default("NEGOTIATION")
  totalAmount     Decimal  @default(0)
  discount        Decimal?
  note            String?
  deliveryAddress String?
  lossReason      String?
  lossComment     String?

  counterpartyId String
  counterparty   Counterparty @relation("DealCounterparty", fields: [counterpartyId], references: [id])
  contactId      String?
  contact        Contact?     @relation("DealContact", fields: [contactId], references: [id], onDelete: SetNull)
  managerId      String
  manager        User         @relation("DealManager", fields: [managerId], references: [id])
  createdById    String
  createdBy      User         @relation("DealCreatedBy", fields: [createdById], references: [id])
  updatedById    String?
  updatedBy      User?        @relation("DealUpdatedBy", fields: [updatedById], references: [id])
  sourceProjectId String?
  sourceProject   Project?    @relation("ProjectDeals", fields: [sourceProjectId], references: [id], onDelete: SetNull)
  sourceAuctionId String?
  sourceAuction   Auction?    @relation("AuctionDeals", fields: [sourceAuctionId], references: [id], onDelete: SetNull)

  items          DealItem[]
  tasks          Task[]
  shipments      Shipment[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([counterpartyId])
  @@index([managerId])
  @@index([sourceProjectId])
  @@index([sourceAuctionId])
  @@map("deals")
}

model DealItem {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation("DealItemProduct", fields: [productId], references: [id], onDelete: SetNull)
  sku       String?
  name      String
  quantity  Decimal  @default(1)
  amount    Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipmentItems ShipmentItem[]

  @@index([dealId])
  @@index([productId])
  @@map("deal_items")
}

model Shipment {
  id                 String   @id @default(cuid())
  number             String   @unique
  dealId             String
  deal               Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status             String   @default("DRAFT")
  plannedDate        DateTime?
  shippedAt          DateTime?
  deliveryAddress    String?
  carrier            String?
  trackingNumber     String?
  recipientContactId String?
  recipientContact   Contact? @relation("ShipmentRecipient", fields: [recipientContactId], references: [id], onDelete: SetNull)
  recipientName      String?
  recipientPhone     String?
  recipientEmail     String?
  docNumber          String?
  note               String?

  items              ShipmentItem[]

  createdById        String?
  createdBy          User?    @relation("ShipmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById        String?
  updatedBy          User?    @relation("ShipmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([dealId])
  @@index([status])
  @@index([plannedDate])
  @@map("shipments")
}

model ShipmentItem {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  dealItemId String
  dealItem   DealItem @relation(fields: [dealItemId], references: [id], onDelete: Cascade)
  quantity   Decimal  @default(0)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shipmentId])
  @@index([dealItemId])
  @@map("shipment_items")
}

// Аукцион (госзакупка) — рождается из проекта: заказчик = конечный
// потребитель проекта, поставщик = дистрибьютор.
model Auction {
  id                   String        @id @default(cuid())
  purchaseNumber       String?
  auctionUrl           String?
  status               String        @default("IN_PROGRESS")
  nmck                 Decimal       @default(0)
  bidsDeadlineAt       DateTime?
  auctionAt            DateTime?
  resultsAt            DateTime?
  participantsCount    Int?
  bidsCount            Int?
  winner               String?
  lossComment          String?
  protocolAttachmentId String?

  projectId         String
  project           Project      @relation("ProjectAuctions", fields: [projectId], references: [id], onDelete: Cascade)
  customerId        String
  customer          Counterparty @relation("AuctionCustomer", fields: [customerId], references: [id])
  supplierId        String
  supplier          Counterparty @relation("AuctionSupplier", fields: [supplierId], references: [id])
  supplierContactId String?
  supplierContact   Contact?     @relation("AuctionSupplierContact", fields: [supplierContactId], references: [id], onDelete: SetNull)
  managerId         String
  manager           User         @relation("AuctionManager", fields: [managerId], references: [id])
  createdById       String?
  createdBy         User?        @relation("AuctionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById       String?
  updatedBy         User?        @relation("AuctionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  items AuctionItem[]
  tasks Task[]
  deals Deal[]        @relation("AuctionDeals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([managerId])
  @@map("auctions")
}

model AuctionItem {
  id        String   @id @default(cuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation("AuctionItemProduct", fields: [productId], references: [id], onDelete: SetNull)
  sku       String?
  name      String
  quantity  Decimal  @default(1)
  amount    Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([auctionId])
  @@index([productId])
  @@map("auction_items")
}

model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  type          String
  status        String    @default("OPEN")
  result        String?
  startAt       DateTime
  endAt         DateTime
  allDay        Boolean   @default(true)

  assigneeId    String
  assignee      User      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById   String
  createdBy     User      @relation("TaskCreatedBy", fields: [createdById], references: [id])

  dealId         String?
  deal           Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  distributorId  String?
  distributor    Counterparty? @relation("TaskDistributor", fields: [distributorId], references: [id], onDelete: SetNull)
  endCustomerId  String?
  endCustomer    Counterparty? @relation("TaskEndCustomer", fields: [endCustomerId], references: [id], onDelete: SetNull)
  auctionId      String?
  auction        Auction?      @relation(fields: [auctionId], references: [id], onDelete: SetNull)

  closedAt      DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([startAt])
  @@index([dealId])
  @@index([projectId])
  @@index([distributorId])
  @@index([endCustomerId])
  @@index([auctionId])
  @@map("tasks")
}

// Настройки CRM: простое key-value хранилище (шаблоны писем и т.п.)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// Заявка с публичной формы обратной связи на сайте
model Lead {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  company     String?
  message     String?
  source      String    @default("Веб-сайт (форма на сайте)")
  status      String    @default("NEW")
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

model Neoset {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  pathname    String
  srcImg      String
  code        Code[]
  images      Images[]

  @@map("neosets")
}

model Images {
  id          Int     @id @default(autoincrement())
  alt         String?
  description String?
  src         String
  neoset      Neoset? @relation(fields: [neosetId], references: [id])
  neosetId    Int?
}

model Code {
  id         Int         @id @default(autoincrement())
  neoset     Neoset?     @relation(fields: [neosetId], references: [id])
  neosetId   Int?
  title      String
  transcript String
  consist    Consist[]
  consistOf  ConsistOf[]

  @@map("codes")
}

model Consist {
  id                   Int     @id @default(autoincrement())
  Code                 Code?   @relation(fields: [codeId], references: [id])
  codeId               Int?
  napkin               String?
  ball                 String?
  pintsetMedium        String?
  pintsetThin          String?
  scalpelRemoveFiber   String?
  scalpelEleven        String?
  clamp                String?
  needleHolder         String?
  container            String?
  bandage              String?
  plasterTrip          String?
  plaster              String?
  plasterPostOperative String?
  plasterFixCatheter   String?
  cover                String?
  coverAperture        String?
  coverAdhesive        String?
}

model ConsistOf {
  id        Int    @id @default(autoincrement())
  code      Code?  @relation(fields: [codeId], references: [id])
  codeId    Int?
  component String
  count     String
  class     String

  @@map("consistOf")
}

model Category {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  content String?
  posts   Post[]
}

model Section {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[]
}

model Post {
  id         String    @id @default(cuid())
  title      String
  content    String
  photoUrl   String?
  postUrl    String?
  categoryId Int?
  sectionId  Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category? @relation(fields: [categoryId], references: [id])
  section    Section?  @relation(fields: [sectionId], references: [id])

  @@map("posts")
}

model Note {
  id          String       @id @default(cuid())
  body        String
  entityType  String
  entityId    String
  pinned      Boolean      @default(false)
  authorId    String
  author      User         @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  attachments Attachment[] @relation("NoteAttachments")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([entityType, entityId])
  @@index([authorId])
  @@map("notes")
}

model Attachment {
  id            String   @id @default(cuid())
  fileName      String
  mimeType      String
  size          Int
  storageKey    String
  entityType    String?
  entityId      String?
  noteId        String?
  note          Note?    @relation("NoteAttachments", fields: [noteId], references: [id], onDelete: Cascade)
  uploadedById  String
  uploadedBy    User     @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([noteId])
  @@index([uploadedById])
  @@map("attachments")
}
