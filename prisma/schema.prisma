// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  position     String?
  role         String   @default("MANAGER")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  counterparties Counterparty[] @relation("CounterpartyCreatedBy")
  projects       Project[]      @relation("ProjectManager")

  @@map("users")
}

model Counterparty {
  id              String   @id @default(cuid())
  type            String
  name            String
  region          String
  inn             String?
  kpp             String?
  ogrn            String?
  okpo            String?
  okved           String?
  bankName        String?
  bankAccount     String?
  bankCorrAccount String?
  bik             String?
  totalRevenue    Decimal  @default(0)
  discount        Decimal?
  phone           String?
  email           String?
  address         String?
  note            String?
  contacts        Contact[]
  createdById     String?
  createdBy       User?    @relation("CounterpartyCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectsAsDistributor Project[] @relation("ProjectDistributor")
  projectsAsEndCustomer Project[] @relation("ProjectEndCustomer")

  @@index([type])
  @@index([region])
  @@map("counterparties")
}

model Project {
  id                String        @id @default(cuid())
  externalAuctionId String
  internalName      String
  status            String        @default("IN_PROGRESS")
  totalAmount       Decimal       @default(0)
  auctionDate       DateTime?
  duplicateComment  String?

  distributorId     String
  distributor       Counterparty  @relation("ProjectDistributor", fields: [distributorId], references: [id])
  endCustomerId     String
  endCustomer       Counterparty  @relation("ProjectEndCustomer", fields: [endCustomerId], references: [id])
  managerId         String
  manager           User          @relation("ProjectManager", fields: [managerId], references: [id])

  items             ProjectItem[]
  contacts          Contact[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([externalAuctionId, endCustomerId])
  @@index([distributorId])
  @@index([endCustomerId])
  @@index([managerId])
  @@map("projects")
}

model ProjectItem {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku       String?
  name      String
  quantity  Decimal  @default(1)
  amount    Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([productId])
  @@map("project_items")
}

model Product {
  id                  String        @id @default(cuid())
  sku                 String        @unique
  name                String
  category            String
  basePrice           Decimal       @default(0)
  packagePrice        Decimal       @default(0)
  recommendedLpuPrice Decimal?
  transportPackQty    Int           @default(0)
  contents            String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  projectItems        ProjectItem[]

  @@index([category])
  @@map("products")
}

model Contact {
  id             String       @id @default(cuid())
  counterpartyId String
  counterparty   Counterparty @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  firstName      String?
  lastName       String?
  phone          String?
  email          String?
  birthDate      DateTime?
  position       String?
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  projects       Project[]

  @@index([counterpartyId])
  @@map("contacts")
}

model Neoset {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  pathname    String
  srcImg      String
  code        Code[]
  images      Images[]

  @@map("neosets")
}

model Images {
  id          Int     @id @default(autoincrement())
  alt         String?
  description String?
  src         String
  neoset      Neoset? @relation(fields: [neosetId], references: [id])
  neosetId    Int?
}

model Code {
  id         Int         @id @default(autoincrement())
  neoset     Neoset?     @relation(fields: [neosetId], references: [id])
  neosetId   Int?
  title      String
  transcript String
  consist    Consist[]
  consistOf  ConsistOf[]

  @@map("codes")
}

model Consist {
  id                   Int     @id @default(autoincrement())
  Code                 Code?   @relation(fields: [codeId], references: [id])
  codeId               Int?
  napkin               String?
  ball                 String?
  pintsetMedium        String?
  pintsetThin          String?
  scalpelRemoveFiber   String?
  scalpelEleven        String?
  clamp                String?
  needleHolder         String?
  container            String?
  bandage              String?
  plasterTrip          String?
  plaster              String?
  plasterPostOperative String?
  plasterFixCatheter   String?
  cover                String?
  coverAperture        String?
  coverAdhesive        String?
}

model ConsistOf {
  id        Int    @id @default(autoincrement())
  code      Code?  @relation(fields: [codeId], references: [id])
  codeId    Int?
  component String
  count     String
  class     String

  @@map("consistOf")
}

model Category {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  content String?
  posts   Post[]
}

model Section {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[]
}

model Post {
  id         String    @id @default(cuid())
  title      String
  content    String
  photoUrl   String?
  postUrl    String?
  categoryId Int?
  sectionId  Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category? @relation(fields: [categoryId], references: [id])
  section    Section?  @relation(fields: [sectionId], references: [id])

  @@map("posts")
}
